# Theme binary assets — large files served by Shopify CDN, not worth tracking
store-data/theme/assets/*.png
store-data/theme/assets/*.jpg
store-data/theme/assets/*.jpeg
store-data/theme/assets/*.gif
store-data/theme/assets/*.webp
store-data/theme/assets/*.svg
store-data/theme/assets/*.ico
store-data/theme/assets/*.woff
store-data/theme/assets/*.woff2
store-data/theme/assets/*.ttf
store-data/theme/assets/*.eot
store-data/theme/assets/*.otf
store-data/theme/assets/*.mp4
store-data/theme/assets/*.mp3
store-data/theme/assets/*.zip
store-data/theme/assets/*.pdf
# Theme text files (.liquid, .json, .css, .js) ARE tracked — they are the work product

# Store data snapshots (regenerated via /pull-store-data)
store-data/pages.json
store-data/navigation.json
store-data/blogs.json
store-data/collections.json
store-data/products-index.csv
store-data/metafield-definitions.json

# Shopify CLI auth tokens
.shopify/
*.shopify

# Environment / secrets
.env
.env.local
.env.*

# Claude Code local settings (user-specific)
.claude/settings.local.json
.claude/worktrees/

# Session activity log (ephemeral, per-user)
docs/session-activity.log

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Node (if any scripts added)
node_modules/
npm-debug.log*
